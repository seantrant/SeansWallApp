{
  "expo": {
    "name": "SeansWallApp",
    "slug": "wall-app",
    "version": "1.0.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "androidStatusBar": {
      "hidden": true,
      "translucent": true
    },
    "android": {
      "package": "com.whywouldiwantausername.wallapp",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "position": "absolute",
          "visibility": "hidden",
          "behavior": "overlay-swipe"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow motion detection to wake the screen"
        }
      ],
      "./plugins/withAndroidNetworkSecurity",
      "./plugins/withSensorLandscape"
    ],
    "extra": {
      "eas": {
        "projectId": "eb9c99e5-d690-4ffe-b379-23ec54be04e0"
      },
      "expo-navigation-bar": {
        "position": "absolute",
        "visibility": "hidden",
        "behavior": "overlay-swipe"
      }
    },
    "owner": "whywouldiwantausername"
  }
}
