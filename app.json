{
  "expo": {
    "name": "SeansWallApp",
    "slug": "wall-app",
    "version": "1.0.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "androidStatusBar": {
      "hidden": true,
      "translucent": true
    },
    "android": {
      "package": "com.whywouldiwantausername.wallapp"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "position": "absolute",
          "visibility": "hidden",
          "behavior": "overlay-swipe"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
